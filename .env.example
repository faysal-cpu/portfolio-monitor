# Finnhub API Key (get from https://finnhub.io)
FINNHUB_API_KEY=your_finnhub_api_key_here

# Alpha Vantage API Key (get from https://www.alphavantage.co/support/#api-key)
# Used as fallback for Canadian TSX stocks that Finnhub free tier doesn't support
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# Reddit API Credentials (get from https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=portfolio-monitor/1.0 by your_reddit_username

# Anthropic Claude API Key (get from https://console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# SendGrid API Key (get from https://app.sendgrid.com or https://console.twilio.com)
# Go to: Settings > API Keys > Create API Key
# The key MUST start with "SG."
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here

# Email Configuration
EMAIL_FROM=your-email@example.com
EMAIL_TO=recipient-email@example.com
